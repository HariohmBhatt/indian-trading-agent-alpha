[Unit]
Description=Indian Trading Agent - Next.js Frontend
Documentation=https://github.com/pradeepsiddappa/indian-trading-agent
After=network-online.target trading-agent-backend.service
Wants=network-online.target trading-agent-backend.service
StartLimitIntervalSec=300
StartLimitBurst=5

[Service]
Type=simple
User=hariohm
Group=hariohm
WorkingDirectory=/home/hariohm/indian-trading-agent/frontend
Environment=NODE_ENV=production
Environment=PORT=3000
Environment=HOSTNAME=0.0.0.0
ExecStart=/usr/bin/npm run start -- -H 0.0.0.0 -p 3000
Restart=on-failure
RestartSec=15
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
